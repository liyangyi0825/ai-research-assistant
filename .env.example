# 复制这个文件，重命名为 .env.local，然后填入真实的密钥
# 注意：.env.local 绝对不能提交到 Git！

# Claude API Key（从 https://console.anthropic.com/ 获取）
ANTHROPIC_API_KEY=your_claude_api_key_here

# Supabase —— 注意要加 NEXT_PUBLIC_ 前缀，浏览器端登录功能才能工作
# 从 Supabase 项目 → Settings → API 页面获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here

# Supabase Service Role Key（步骤 6 管理页面用，从 Settings → API 获取 service_role key）
# ⚠️ 权限极高，绝不能泄露！只放在 .env.local 和 Vercel 后台
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 管理员邮箱（步骤 6 监控页面用，填你自己的登录邮箱）
ADMIN_EMAIL=your_email@example.com

# 网站域名（生产环境必填，用于 Magic Link 登录回调跳转到正确域名）
# 本地开发不需要填，留空即可
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Anthropic API 中转地址（中国大陆服务器必填，用 Cloudflare Workers 绕过屏蔽）
# 部署 Worker 后填入，格式：https://your-worker-name.your-subdomain.workers.dev
# 海外服务器或本地开发不需要填
ANTHROPIC_API_BASE_URL=

# Resend 邮件通知（有新反馈时发邮件给管理员）
# 从 https://resend.com 注册后获取 API Key（免费版每天 100 封）
# RESEND_FROM_EMAIL 填写已在 Resend 验证过的发件人地址（如 noreply@iyanhub.com）
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@iyanhub.com
